# LLM Provider — CrewAI uses OpenAI-compatible API by default

# Option 1: DeepSeek (recommended, ultra-low cost)
# Sign up at https://platform.deepseek.com to get an API key
OPENAI_API_KEY=sk-deepseek-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL_NAME=deepseek-chat

# Option 2: OpenAI
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_NAME=gpt-4o

# Option 3: Ollama (local, free)
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL_NAME=ollama/llama3.1
